      "WebSearch",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Skill"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D*)",
      "Bash(rm -rf /)",
