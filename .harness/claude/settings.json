      "Read(.env.*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(id_rsa*)",
      "Read(credentials*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit --amend*)",
      "Bash(rm -rf:*)"
    ]
